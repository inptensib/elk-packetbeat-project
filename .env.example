# ============================================================
# ELK Stack PacketBeat - Variables d'environnement
# Copier ce fichier en .env et ajuster les valeurs si besoin
# NE PAS committer le fichier .env dans Git
# ============================================================

# Version ELK (doit etre identique pour tous les composants)
ELK_VERSION=8.13.4

# Hote Elasticsearch (dans le reseau Docker interne)
ELASTICSEARCH_HOST=http://elasticsearch:9200

# Memoire JVM pour Elasticsearch
ES_JAVA_OPTS=-Xms512m -Xmx512m

# IMPORTANT : securite Elastic desactivee pour ce projet pedagogique local.
# Ne pas utiliser cette configuration en production.
XPACK_SECURITY_ENABLED=false
